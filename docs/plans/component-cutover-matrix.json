    "wave11": {
      "landing": "Reducer-backed planning status, queue/control JSON, and operator-facing status projections are live over compatibility run records.",
      "promotedComponents": [
        "reducer-state-spine",
        "gate-verdict-spine",
        "planning-status",
        "queue-json-surface"
      ],
      "nextExecutableWave": 12,
      "nextWork": "Land structured result envelopes and proof lifecycle, route new-run persistence through wave-results, and make replay mismatches semantic while replay ratification remains later work.",
      "promotionScopeNote": "TUI, launcher, scheduler, and trace components consume the reducer-backed projections but keep their existing levels until their own waves promote them.",
      "remainingCompatibilityBoundary": "Wave 11 stops at reducer-backed queue/control truth over compatibility run records; proof/closure and replay remain later work at this stage.",
      "qaClosure": "Wave 11 cont-QA closure is owned by A0 and is not claimed by the component matrix."
    },
    "wave12": {
      "landing": "Structured result envelopes now land under .wave/state/results, proof surfaces are envelope-first for the active run and the latest completed or failed run, closure consumers read stored envelopes first for new runs, and replay readback compares canonical envelope identity while ratification stays compatibility-backed.",
      "promotedComponents": [
        "result-envelope-lifecycle",
        "proof-lifecycle-spine",
        "envelope-first-closure"
      ],
      "nextExecutableWave": 13,
      "nextWork": "Break up runtime orchestration and add mandatory post-agent gate foundations in Wave 13; Wave 14 adds targeted mid-wave checkpoints and retry, and Wave 19 adds planner-emitted invariants plus staged gate plans.",
      "promotionScopeNote": "Queue/control truth remains reducer-backed over compatibility run records; gate verdict helpers and launcher substrate consume the landed result-envelope boundary but keep their existing levels.",
      "remainingCompatibilityBoundary": "Replay ratification still depends on compatibility run and trace artifacts, legacy attempts still use explicit compatibility adapters, and structured result envelopes are not yet the universal reducer/control authority.",
      "qaClosure": "Wave 12 cont-QA closure is owned by A0 and is not claimed by the component matrix."
    }
  },
